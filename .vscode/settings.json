{
    "workbench.colorTheme": "Default Dark Modern",
    
    "editor.fontSize": 12,
    "editor.fontFamily": "Consolas, 'Courier New', monospace",
    "editor.lineHeight": 24,
    "editor.cursorBlinking": "phase",
    
    "editor.renderWhitespace": "none",
    "editor.bracketPairColorization.enabled": false,
    "editor.minimap.enabled": false,
    "editor.scrollbar.vertical": "hidden",
    "editor.wordWrap": "on",
    "editor.smoothScrolling": true,
    
    "workbench.colorCustomizations": {
        "editor.background": "#20242b",
        "editor.foreground": "#b9c1c9",
        "editorLineNumber.foreground": "#727b86",
        "editorLineNumber.activeForeground": "#afb8c1",
        "editorCursor.foreground": "#aab3bd",
        "editor.selectionBackground": "#36424f66",
        "editor.linkedEditingBackground": "#5f6f7f24",
        "statusBar.background": "#1b1f24",
        "statusBar.foreground": "#bfc7cf",
        "titleBar.activeBackground": "#1b1f24",
        "titleBar.activeForeground": "#bfc7cf",
        "sideBar.background": "#1b1f24",
        "sideBar.foreground": "#bfc7cf"
    },
    "python-envs.defaultEnvManager": "ms-python.python:system",
      // Prevent Copilot (Agent mode) from automatically opening files it creates or edits
      "github.copilot.agent.openFilesOnChange": false,
      "github.copilot.chat.agent.openFilesOnChange": false,

  // (optional) also stop the initial “create file” tab from opening
      "github.copilot.agent.openFilesOnCreate": false,
      "github.copilot.chat.agent.openFilesOnCreate": false
}
