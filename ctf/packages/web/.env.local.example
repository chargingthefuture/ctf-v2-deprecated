# Required for Clerk (build/runtime)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Mobile can reuse this Railway production public key when MOBILE_CLERK_PUBLISHABLE_KEY is not set.

# Optional Clerk domain overrides for 3-environment routing
NEXT_PUBLIC_CLERK_PRODUCTION_DOMAIN=
NEXT_PUBLIC_CLERK_RAILWAY_STAGING_DOMAIN=
NEXT_PUBLIC_CLERK_VERCEL_STAGING_DOMAIN=
NEXT_PUBLIC_CLERK_STAGING_DOMAIN=
NEXT_PUBLIC_CLERK_DEV_DOMAIN=

# Optional aliases used by Vercel design deployment
VERCEL_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
VERCEL_CLERK_SECRET_KEY=

# Required for Neon persistence
DATABASE_URL=

# Required for Stream token + channel provisioning
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_KEY=
STREAM_API_SECRET=

# Optional app/runtime values
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_OBSERVABILITY_PROVIDER=noop
